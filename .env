APP_NAME="Astro Platform"
APP_VERSION="0.1.0"
APP_ENV="development"
DEBUG=true

# Use SQLite for local dev/tests when Postgres is not available
DATABASE_URL="sqlite:///./astro_platform.db"
DATABASE_ASYNC_URL="sqlite+aiosqlite:///./astro_platform.db"

DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

SECRET_KEY="dev-secret-key-not-for-production"
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

DEFAULT_SCHOOL="luz_e_sombra"
DEFAULT_HOUSE_SYSTEM="placidus"
