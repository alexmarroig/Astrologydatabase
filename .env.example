APP_NAME="Astro Platform"
APP_VERSION="0.1.0"
APP_ENV="development"
DEBUG=true

# Database
DATABASE_URL="postgresql://astro:astro@localhost:5432/astro_platform"
DATABASE_ASYNC_URL="postgresql+asyncpg://astro:astro@localhost:5432/astro_platform"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Security
SECRET_KEY="change-me-in-production-use-openssl-rand-hex-32"
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Editorial defaults
DEFAULT_SCHOOL="luz_e_sombra"
DEFAULT_HOUSE_SYSTEM="placidus"

# Optional external integrations
OPENAI_API_KEY=""
LLM_MODEL="gpt-4o-mini"
LLM_TEMPERATURE=0.3
REDIS_URL="redis://localhost:6379/0"

# Astrology calculation
EPHEMERIS_PROVIDER="analytical"
# SWISSEPH_EPHEMERIS_PATH="C:/ephemeris-data"
